<idea-plugin>
    <id>com.example.swaggerViewer</id>
    <name>Swagger Viewer</name>
    <vendor>dabean</vendor>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Tool Window: Spring 소스 파일 어노테이션 미리보기 + YAML/JSON 스펙 파일 미리보기 -->
        <toolWindow
                id="Swagger Viewer"
                anchor="right"
                factoryClass="com.example.swaggerViewer.view.SwaggerViewerToolWindowFactory"/>

    </extensions>
</idea-plugin>
