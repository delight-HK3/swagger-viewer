<idea-plugin>
    <id>com.github.delight-HK3.swagger-viewer</id>
    <name>Swagger Viewer</name>
    <vendor email="dabin49140@gmail.com" url="https://github.com/delight-HK3">delight-HK3</vendor>

    <!-- Base platform — required for Tool Window, PSI, Document API -->
    <depends>com.intellij.modules.platform</depends>
    <!-- Java PSI — required for @RestController / @Operation annotation parsing -->
    <depends>com.intellij.java</depends>
    <!-- YAML plugin — required for OpenAPI spec file (.yaml/.yml) preview -->
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Tool Window: Spring source file annotation preview + YAML/JSON spec file preview -->
        <toolWindow
                id="Swagger Viewer"
                anchor="right"
                factoryClass="com.github.swaggerViewer.view.SwaggerViewerToolWindowFactory"/>

    </extensions>
</idea-plugin>
