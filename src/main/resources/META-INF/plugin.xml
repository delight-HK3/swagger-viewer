<idea-plugin>
    <id>com.github.swaggerViewer</id>
    <name>Swagger Viewer</name>
    <vendor>delight-HK3</vendor>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Tool Window: Spring source file annotation preview + YAML/JSON spec file preview -->
        <toolWindow
                id="Swagger Viewer"
                anchor="right"
                factoryClass="com.github.swaggerViewer.view.SwaggerViewerToolWindowFactory"/>

    </extensions>
</idea-plugin>
